# QA runner fixtures (scripts/qa/*.mjs). See scripts/qa/README.md.
#
# Copy this file to .env.qa.local (gitignored) and fill in real values.
# Runners load it via Node's --env-file-if-exists flag, so it's optional —
# a missing file fails with a clear pointer back to this template.

# UID with rich graded-pick history in the Firebase project the build uses.
# Required by `qa:chunks` and `qa:cache`. Used to navigate to `/user/<uid>`.
#
# Pick a UID that:
#   - exists in the project,
#   - has a populated `users/{uid}` materialized aggregate (post-rollup),
#   - has graded picks across enough shows that the initial WebChannel
#     read is comfortably > 5 kB (for `qa:cache` thresholds).
QA_PUBLIC_PROFILE_UID=YOUR_STAGING_FIREBASE_UID

# Registered Firebase App Check **debug** token (UUID string). Required for
# `qa:cache` and recommended for `qa:chunks` when routes touch Firestore.
# Firebase Console → App Check → Web app → Manage debug tokens.
QA_APPCHECK_DEBUG_TOKEN=YOUR_REGISTERED_APPCHECK_DEBUG_UUID

# Email/password for a **dedicated test account** (issue #349). Firestore rules
# require signed-in reads for profile data; `qa:cache` signs in via the splash
# `/?login=true` modal before measuring cache behavior.
QA_TEST_EMAIL=YOUR_QA_TEST_EMAIL
QA_TEST_PASSWORD=YOUR_QA_TEST_PASSWORD

# Deployed Vercel preview origin for `npm run qa:preview-headers` (issue #348).
# Example: https://set-picks-git-feat-branch-user.vercel.app
# Optional locally; CI can use repo **Variables** / secrets. Omit to SKIP.
# QA_PREVIEW_BASE_URL=

# Vercel Deployment Protection bypass secret (Automation). Optional if previews
# are public. Sent as `x-vercel-protection-bypass`.
# QA_VERCEL_PROTECTION_BYPASS=
# `npm run qa:cache` only — the headless browser cannot complete ReCAPTCHA
# Enterprise; App Check accepts a fixed debug token you add under Firebase
# Console → App Check → Apps → (web app) → Manage debug tokens.
# Generate any UUID v4 locally, register it once, paste the same string here.
QA_APPCHECK_DEBUG_TOKEN=YOUR_REGISTERED_APPCHECK_DEBUG_UUID
