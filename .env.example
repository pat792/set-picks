# Google Analytics 4 — optional. Leave unset for local dev to avoid sending hits to production.
# Staging/production builds should set this to your GA4 Measurement ID (G-XXXXXXXXXX).
VITE_GA_MEASUREMENT_ID=

# --- External setlist APIs (epic #42, issue #141) ---
# Which provider `fetchSetlistRaw` uses: phishin | phishnet
VITE_SETLIST_API_SOURCE=phishin

# Phish.net v5: `api.phish.net` does not allow browser `fetch` (CORS). With VITE_SETLIST_API_SOURCE=phishnet,
# set VITE_USE_CALLABLE_PHISHNET_SETLIST=true locally and use deployed `getPhishnetSetlist` + Secret Manager key.
# Optional: VITE_PHISHNET_API_KEY only if callable is false (e.g. non-browser tools); never ship prod secrets in VITE_*.
# VITE_PHISHNET_API_KEY=
# VITE_USE_CALLABLE_PHISHNET_SETLIST=true
