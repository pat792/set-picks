# Google Analytics 4 — optional. Leave unset for local dev to avoid sending hits to production.
# Staging/production builds should set this to your GA4 Measurement ID (G-XXXXXXXXXX).
VITE_GA_MEASUREMENT_ID=

# --- External setlist APIs (epic #42, issue #141) ---
# Which provider `fetchSetlistRaw` uses: phishin | phishnet
VITE_SETLIST_API_SOURCE=phishin

# Phish.net v5 API key (query param `apikey`). Use only for LOCAL direct fetch when the
# callable proxy is disabled (see below). Never put a production secret in VITE_*.
# VITE_PHISHNET_API_KEY=

# When `true` and VITE_SETLIST_API_SOURCE=phishnet, setlist fetch uses the Firebase Callable
# `getPhishnetSetlist` (server secret PHISHNET_API_KEY). Set this in staging/production builds;
# leave unset or false locally if you use VITE_PHISHNET_API_KEY + direct fetch.
# VITE_USE_CALLABLE_PHISHNET_SETLIST=
