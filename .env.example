# Google Analytics 4 — optional. Leave unset for local dev to avoid sending hits to production.
# Staging/production builds should set this to your GA4 Measurement ID (G-XXXXXXXXXX).
VITE_GA_MEASUREMENT_ID=

# Firebase Cloud Messaging Web Push (issue #273).
# Required for `requestFcmDeviceToken()` to mint a browser/device token.
# This is the public VAPID key from Firebase Console > Cloud Messaging > Web configuration.
VITE_FCM_VAPID_KEY=

# Firebase Auth custom domain (issue #282). Leave unset to use the default
# `set-picks.firebaseapp.com` (original Firebase-hosted OAuth handler URL).
# Set to `www.setlistpickem.com` to rebrand the Google OAuth popup and
# consent screen — requires the Vercel rewrite in vercel.json that proxies
# `/__/auth/*` and `/__/firebase/init.json` back to the Firebase project,
# and `www.setlistpickem.com` listed as an Authorized domain in Firebase
# Auth and as an Authorized redirect URI (`/__/auth/handler`) on the
# Google OAuth client.
# VITE_FIREBASE_AUTH_DOMAIN=

# --- External setlist APIs (epic #42) ---
# phishin | phishnet
VITE_SETLIST_API_SOURCE=phishin

# Phish.net: use Firebase Callable getPhishnetSetlist + Secret PHISHNET_API_KEY only (see README).
# Set true whenever VITE_SETLIST_API_SOURCE=phishnet (local + prod). Do NOT add VITE_PHISHNET_API_KEY —
# any VITE_* variable is compiled into the client JS and is not secret.
# VITE_USE_CALLABLE_PHISHNET_SETLIST=true
#
# Private record (gitignored .env only — never VITE_). Sync to Secret Manager: npm run secrets:sync-phishnet
# PHISHNET_API_KEY=

# Optional: full URL to song-catalog.json on your own CDN (anonymous GET + CORS). If unset, the app uses
# Firebase getDownloadURL() for the default bucket object (Storage rules apply).
# VITE_SONG_CATALOG_URL=

# Optional: set true to render reserved sponsor/ad placements (shared/ui SponsorSlot; ads epic #419).
# Off by default — placements render nothing when unset.
# VITE_ENABLE_SPONSOR_SLOTS=true

# --- Vercel API Functions ---
# Firebase Admin SDK service account for server-side Firestore access (issue #128).
# Required for the /join/:code OG tag function (api/invite/[code].js) to resolve pool names.
# Set in Vercel project settings (Environment Variables) — never commit this value.
# Value: JSON string of the Firebase service account key downloaded from
#   Firebase Console > Project Settings > Service accounts > Generate new private key.
# If unset, the function falls back to Application Default Credentials (GCP environments only)
# or serves default OG tags without a pool name lookup.
# FIREBASE_SERVICE_ACCOUNT=
